#include <bits/stdc++.h>
using namespace std;

int binarySearch(int arr[], int n, int key) {
    int low = 0, high = n - 1;

    while (low <= high) {
        int mid = low + (high - low) / 2;

        if (arr[mid] == key)
            return mid;          // found
        else if (arr[mid] < key)
            low = mid + 1;       // search right half
        else
            high = mid - 1;      // search left half
    }
    return -1;   // not found
}

int main() {
    int n;
    cin >> n;   // size of array

    int arr[n];
    for(int i = 0; i < n; i++) {
        cin >> arr[i];   // input elements (must be sorted)
    }

    int key;
    cin >> key;         // element to search

    int result = binarySearch(arr, n, key);

    if(result == -1)
        cout << "Element not found";
    else
        cout << "Element found at index " << result;

    return 0;
}